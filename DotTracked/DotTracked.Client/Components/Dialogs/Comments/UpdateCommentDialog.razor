@using System.ComponentModel.DataAnnotations
@using DotTracked.Shared.DTOs
<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Update Comment</MudText>
    </TitleContent>

    <DialogContent>
        <EditForm Model="@_input" OnValidSubmit="UpdateComment" id="editForm">
            <DataAnnotationsValidator/>

            <MudTextField @bind-Value="_input.Comment" For="@(() => _input.Comment)"
                          Label="Comment" Placeholder="Type here..." Lines="3" MaxLines="8"/>
        </EditForm>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton ButtonType="ButtonType.Submit" form="editForm" Color="Color.Primary" Variant="Variant.Filled">Update</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public CommentDto CommentDto { get; set; } = new();

    private readonly InputModel _input = new();

    protected override void OnInitialized()
    {
        _input.Comment = CommentDto.Content;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void UpdateComment()
    {
        CommentDto.Content = _input.Comment;
        CommentDto.UpdatedAt = DateTime.UtcNow;

        MudDialog.Close(DialogResult.Ok(CommentDto));
    }

    public class InputModel
    {
        [Required]
        [StringLength(1000, ErrorMessage = "Description length can't be more than 1000 characters.")]
        public string Comment { get; set; }
    }

}