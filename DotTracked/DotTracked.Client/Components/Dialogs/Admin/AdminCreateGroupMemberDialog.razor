@using DotTracked.Shared.DTOs
<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Add Group Member</MudText>
    </TitleContent>

    <DialogContent>
        <MudText>Select the user you want to add to this group</MudText>
        <MudSelect @bind-Value="_selectedUser" T="AdminUserDto" Label="Selected User">
            @foreach (var user in Users)
            {
                <MudSelectItem Value="user">
                    <MudStack Row AlignItems="AlignItems.Center">
                        <b>@($"{user.FirstName} {user.LastName}")</b>
                        <MudText>(@user.Email)</MudText>
                    </MudStack>
                </MudSelectItem>
            }
        </MudSelect>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton OnClick="CreateGroupMember" Color="Color.Primary" Variant="Variant.Filled" Disabled="_selectedUser == null">Create</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public List<AdminUserDto> Users { get; set; } = [];

    private AdminUserDto? _selectedUser;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void CreateGroupMember()
    {
        MudDialog.Close(DialogResult.Ok(_selectedUser));
    }

}