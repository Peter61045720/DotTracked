@using System.ComponentModel.DataAnnotations
@using DotTracked.Shared.DTOs
<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Add Work Log</MudText>
    </TitleContent>

    <DialogContent>
        <EditForm Model="@_input" OnValidSubmit="CreateWorkLog" id="editForm">
            <DataAnnotationsValidator/>

            <MudGrid Spacing="4">
                <MudItem xs="6">
                    <MudDatePicker @bind-Date="_input.Date" For="@(() => _input.Date)"
                                   Label="Date" PickerVariant="PickerVariant.Dialog" ShowToolbar="false"/>
                </MudItem>
                <MudItem xs="6">
                    <MudTimePicker @bind-Time="_input.Time" For="@(() => _input.Time)"
                                   Label="Time" PickerVariant="PickerVariant.Dialog" Editable="true"/>
                </MudItem>

                <MudItem xs="4">
                    <MudNumericField @bind-Value="_input.Hours" For="@(() => _input.Hours)"
                                     Label="Hours" Min="0" Max="23"/>
                </MudItem>
                <MudItem xs="4">
                    <MudNumericField @bind-Value="_input.Minutes" For="@(() => _input.Minutes)"
                                     Label="Minutes" Min="0" Max="59"/>
                </MudItem>
                <MudItem xs="4">
                    <MudNumericField @bind-Value="_input.Seconds" For="@(() => _input.Seconds)"
                                     Label="Seconds" Min="0" Max="59"/>
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_input.Description" For="@(() => _input.Description)"
                                  Label="Description" Lines="6" Immediate="true"/>
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton ButtonType="ButtonType.Submit" form="editForm" Color="Color.Primary" Variant="Variant.Filled">Create</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    private readonly InputModel _input = new();

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void CreateWorkLog()
    {
        var currentTime = DateTime.UtcNow;

        var workLogDto = new WorkLogDto
        {
            Description = _input.Description,
            TimeSpentSeconds = _input.Hours * 3600 + _input.Minutes * 60 + _input.Seconds,
            DateOfLogging = _input.Date!.Value.Date + _input.Time!.Value,
            IsOwner = true,
            CreatedAt = currentTime,
            UpdatedAt = currentTime
        };

        MudDialog.Close(DialogResult.Ok(workLogDto));
    }

    public class InputModel
    {
        [Required(ErrorMessage = "You must select a date")]
        public DateTime? Date { get; set; }

        [Required(ErrorMessage = "You must select a timespan")]
        public TimeSpan? Time { get; set; }

        [Required]
        [Range(0, 23, ErrorMessage = "Hours must be between 0 and 23")]
        public int Hours { get; set; }

        [Required]
        [Range(0, 59, ErrorMessage = "Minutes must be between 0 and 59")]
        public int Minutes { get; set; }

        [Required]
        [Range(0, 59, ErrorMessage = "Seconds must be between 0 and 59")]
        public int Seconds { get; set; }

        [Required]
        [StringLength(400, ErrorMessage = "Description length can't be more than 400 characters.")]
        public string Description { get; set; }
    }

}