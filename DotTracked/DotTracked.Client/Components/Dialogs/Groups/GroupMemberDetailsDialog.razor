@using DotTracked.Shared.DTOs
<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Member Details</MudText>
    </TitleContent>

    <DialogContent>
        <MudStack Spacing="4">
            <MudTextField @bind-Value="UserDto.Email" Label="Email" ReadOnly="true"/>
            <MudTextField @bind-Value="UserDto.DisplayName" Label="Display Name" ReadOnly="true"/>
            <MudTextField @bind-Value="UserDto.FirstName" Label="First Name" ReadOnly="true"/>
            <MudTextField @bind-Value="UserDto.LastName" Label="Last Name" ReadOnly="true"/>
        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Close" Color="Color.Primary" Variant="Variant.Filled">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public UserDto UserDto { get; set; } = new();

    public void Close()
    {
        MudDialog.Close();
    }

}