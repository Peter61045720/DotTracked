@inherits LayoutComponentBase
@layout MainLayout

<MudDrawer Open="true" Variant="@DrawerVariant.Persistent" ClipMode="DrawerClipMode.Always" Elevation="4">
    <MudDrawerHeader>
        <MudText Typo="Typo.h6">Analytics</MudText>
    </MudDrawerHeader>
    <MudNavMenu>
        <MudNavLink Href="/analytics" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.ViewKanban" IconColor="Color.Inherit">Board</MudNavLink>
        <MudNavLink Href="/analytics/timeline" Icon="@Icons.Material.Filled.ViewTimeline" IconColor="Color.Inherit">Timeline</MudNavLink>
        <MudNavLink Href="/analytics/reports" Icon="@Icons.Material.Filled.Timer" IconColor="Color.Inherit">Reports</MudNavLink>
    </MudNavMenu>
</MudDrawer>

<MudMainContent Class="ma-0 pt-8">
    @Body
</MudMainContent>