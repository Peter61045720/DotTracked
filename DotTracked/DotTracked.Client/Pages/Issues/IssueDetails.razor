@page "/issues/{id:guid}"
@using System.ComponentModel.DataAnnotations
@using DotTracked.Client.Components
@using DotTracked.Client.Components.Dialogs
@using DotTracked.Client.Components.Dialogs.Comments
@using DotTracked.Client.Components.Dialogs.WorkLogs
@using DotTracked.Client.Constants
@using DotTracked.Client.Services
@using DotTracked.Shared.Constants
@using DotTracked.Shared.DTOs
@using DotTracked.Shared.Enums
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = Roles.AppUser)]

@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IIssueService IssueService
@inject IWorkLogService WorkLogService
@inject ICommentService CommentService
@inject IDialogService DialogService

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    @if (_issueDto == null)
    {
        <CenteredSpinner/>
    }
    else
    {
        <MudButton OnClick="NavigateBack" StartIcon="@Icons.Material.Filled.ChevronLeft" Color="Color.Primary">Back to list</MudButton>

        <MudText Typo="Typo.h5" Class="my-6">Issue Details</MudText>

        <MudPaper Elevation="4" Class="pa-4">
            <MudTabs Centered="true" Rounded="true" Outlined="true" TabPanelsClass="pt-6">
                <MudTabPanel Text="Info" Icon="@Icons.Material.Filled.Article">
                    <MudGrid Spacing="6">
                        <MudItem xs="6">
                            <MudText>Title:</MudText>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText>@_issueDto.Title</MudText>
                        </MudItem>

                        <MudItem xs="6">
                            <MudText>Description:</MudText>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText>@_issueDto.Description</MudText>
                        </MudItem>

                        <MudItem xs="6">
                            <MudText>Priority:</MudText>
                        </MudItem>
                        <MudItem xs="6">
                            <MudChip T="string" Color="GetPriorityColor(_issueDto.Priority)" Class="ml-n3">
                                @_issueDto.Priority.ToString()
                            </MudChip>
                        </MudItem>

                        <MudItem xs="6">
                            <MudText>Status:</MudText>
                        </MudItem>
                        <MudItem xs="6">
                            <MudChip T="string" Color="GetStatusColor(_issueDto.Status)" Class="ml-n3">
                                @_issueDto.Status.ToString()
                            </MudChip>
                        </MudItem>

                        <MudItem xs="6">
                            <MudText>Start Date:</MudText>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText>@DateOnly.FromDateTime(_issueDto.StartDate)</MudText>
                        </MudItem>

                        <MudItem xs="6">
                            <MudText>Due Date:</MudText>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText>@DateOnly.FromDateTime(_issueDto.DueDate)</MudText>
                        </MudItem>

                        <MudItem xs="6">
                            <MudText>Estimated time:</MudText>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText>@FormatTime(_issueDto.EstimatedSeconds)</MudText>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
                <MudTabPanel Text="Work logs" Icon="@Icons.Material.Filled.AccessTime">
                    @if (_workLogs == null)
                    {
                        <CenteredSpinner/>
                    }
                    else if (_workLogs.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Class="mb-4">No work logs available</MudAlert>
                        <MudButton OnClick="CreateWorkLogAsync" StartIcon="@Icons.Material.Filled.MoreTime" Color="Color.Primary" Variant="Variant.Filled">Log work</MudButton>
                    }
                    else
                    {
                        <MudStack Row AlignItems="AlignItems.Center">
                            <MudButton OnClick="CreateWorkLogAsync" StartIcon="@Icons.Material.Filled.MoreTime" Color="Color.Primary" Variant="Variant.Filled" Class="mb-4">Log work</MudButton>
                            <MudSpacer/>
                            <MudText>Total time logged: @_totalTime</MudText>
                        </MudStack>

                        <MudDivider/>

                        <MudList T="string">
                            @foreach (var workLog in _workLogs)
                            {
                                <MudListItem OnClick="@(() => OpenWorkLogDetailsDialogAsync(workLog))">
                                    <MudStack Row AlignItems="AlignItems.Center">
                                        @{
                                            var loggedTime = GetTimeSpan(workLog.TimeSpentSeconds);
                                        }

                                        <MudText>@loggedTime.Hours hours</MudText>
                                        <MudText>@loggedTime.Minutes minutes</MudText>
                                        <MudSpacer/>
                                        <MudText>@workLog.DateOfLogging</MudText>

                                        @if (workLog.IsOwner)
                                        {
                                            <MudIconButton OnClick="@(() => UpdateWorkLogAsync(workLog))" Icon="@Icons.Material.Filled.Edit" Size="Size.Small"/>
                                            <MudIconButton OnClick="@(() => DeleteWorkLogAsync(workLog))" Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"/>
                                        }
                                    </MudStack>
                                </MudListItem>
                                <MudDivider/>
                            }
                        </MudList>
                    }
                </MudTabPanel>
                <MudTabPanel Text="Comments" Icon="@Icons.Material.Filled.Chat">
                    <MudText Align="Align.Right" Class="mb-4">Number of comments: @_commentCount</MudText>

                    <EditForm Model="@_input" OnValidSubmit="CreateCommentAsync">
                        <DataAnnotationsValidator/>

                        <MudTextField @bind-Value="_input.Comment" For="@(() => _input.Comment)"
                                      Label="Comment" Placeholder="Type here..." Lines="3" MaxLines="8" Variant="Variant.Outlined"/>

                        <MudStack Row Justify="Justify.FlexEnd">
                            <MudButton ButtonType="ButtonType.Submit" EndIcon="@Icons.Material.Filled.Send" Color="Color.Primary" Variant="Variant.Filled" Class="my-4">Send</MudButton>
                        </MudStack>
                    </EditForm>

                    @if (_comments == null)
                    {
                        <CenteredSpinner/>
                    }
                    else if (_comments.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Class="mb-4">No comments available</MudAlert>
                    }
                    else
                    {
                        <MudDivider/>

                        <MudList T="string">
                            @foreach (var comment in _comments)
                            {
                                <MudListItem>
                                    <MudStack Row AlignItems="AlignItems.Start">
                                        <MudAvatar Color="Color.Primary">@comment.AvatarText</MudAvatar>
                                        <MudStack Style="width: 100%;">
                                            <MudStack Row AlignItems="AlignItems.Center">
                                                <MudText Color="Color.Primary">@comment.CreatorEmail</MudText>
                                                <MudText Typo="Typo.body2">@comment.CreatedAt</MudText>
                                                <MudSpacer/>

                                                @if (comment.IsOwner)
                                                {
                                                    <MudIconButton OnClick="@(() => UpdateCommentAsync(comment))" Icon="@Icons.Material.Filled.Edit" Size="Size.Small"/>
                                                    <MudIconButton OnClick="@(() => DeleteCommentAsync(comment))" Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"/>
                                                }
                                            </MudStack>

                                            <MudSpacer/>

                                            <MudText Align="Align.Justify">@comment.Content</MudText>
                                        </MudStack>
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudTabPanel>
            </MudTabs>
        </MudPaper>
    }
</MudContainer>

@code {

    [Parameter]
    public Guid Id { get; set; }

    private IssueDto? _issueDto;

    private List<WorkLogDto>? _workLogs;

    private List<CommentDto>? _comments;

    private TimeSpan _totalTime;

    private InputModel _input = new();

    private int _commentCount;

    protected override async Task OnInitializedAsync()
    {
        _issueDto = await IssueService.GetIssueByIdAsync(Id);
        _workLogs = await WorkLogService.GetWorkLogsAsync(Id);
        _comments = await CommentService.GetCommentsAsync(Id);
        _totalTime = TimeSpan.FromSeconds(await WorkLogService.GetTotalLoggedTimeAsync(Id));
        _commentCount = await CommentService.GetCommentCountAsync(Id);
    }

    public async Task OpenWorkLogDetailsDialogAsync(WorkLogDto workLogDto)
    {
        var parameters = new DialogParameters<WorkLogDetailsDialog>
        {
            { x => x.WorkLogDto, workLogDto }
        };

        await DialogService.ShowAsync<WorkLogDetailsDialog>("Work Log Details", parameters, DialogSettings.Small);
    }

    public async Task CreateWorkLogAsync()
    {
        var dialog = await DialogService.ShowAsync<CreateWorkLogDialog>("Create Work Log", DialogSettings.Small);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is WorkLogDto newWorkLogDto)
        {
            newWorkLogDto = await WorkLogService.CreateWorkLogAsync(Id, newWorkLogDto);
            _workLogs?.Add(newWorkLogDto);
            _totalTime = TimeSpan.FromSeconds(_workLogs!.Sum(w => w.TimeSpentSeconds));
            Snackbar.Add("Work log created successfully", Severity.Success);
        }
    }

    public async Task UpdateWorkLogAsync(WorkLogDto workLogDto)
    {
        var parameters = new DialogParameters<UpdateWorkLogDialog>
        {
            { x => x.WorkLogDto, workLogDto }
        };

        var dialog = await DialogService.ShowAsync<UpdateWorkLogDialog>("Update Work Log", parameters, DialogSettings.Small);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is WorkLogDto updatedWorkLogDto)
        {
            await WorkLogService.UpdateWorkLogAsync(Id, workLogDto.Id, updatedWorkLogDto);
            _totalTime = TimeSpan.FromSeconds(_workLogs!.Sum(w => w.TimeSpentSeconds));
            Snackbar.Add("Work log updated successfully", Severity.Success);
        }
    }

    public async Task DeleteWorkLogAsync(WorkLogDto workLogDto)
    {
        var parameters = new DialogParameters<ConfirmDeleteDialog>
        {
            { x => x.ItemType, "Work Log" },
            { x => x.ItemName, $"logged work at {workLogDto.DateOfLogging}" }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDeleteDialog>("Delete Work Log", parameters, DialogSettings.ExtraSmall);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await WorkLogService.DeleteWorkLogAsync(Id, workLogDto.Id);
            _workLogs?.Remove(workLogDto);
            _totalTime = TimeSpan.FromSeconds(_workLogs!.Sum(w => w.TimeSpentSeconds));
            Snackbar.Add("Work log deleted successfully", Severity.Success);
        }
    }

    public async Task CreateCommentAsync()
    {
        var newComment = await CommentService.CreateCommentAsync(Id, new CommentDto { Content = _input.Comment });
        _comments?.Add(newComment);
        _commentCount++;
        _input = new InputModel();
        Snackbar.Add("Comment created successfully", Severity.Success);
    }

    public async Task UpdateCommentAsync(CommentDto commentDto)
    {
        var parameters = new DialogParameters<UpdateCommentDialog>
        {
            { x => x.CommentDto, commentDto }
        };

        var dialog = await DialogService.ShowAsync<UpdateCommentDialog>("Update Comment", parameters, DialogSettings.Small);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is CommentDto updatedCommentDto)
        {
            await CommentService.UpdateCommentAsync(Id, commentDto.Id, updatedCommentDto);
            Snackbar.Add("Comment updated successfully", Severity.Success);
        }
    }

    public async Task DeleteCommentAsync(CommentDto commentDto)
    {
        var parameters = new DialogParameters<ConfirmDeleteDialog>
        {
            { x => x.ItemType, "Comment" },
            { x => x.ItemName, $"comment written by {commentDto.CreatorEmail} on {commentDto.CreatedAt}" }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDeleteDialog>("Delete Comment", parameters, DialogSettings.ExtraSmall);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await CommentService.DeleteCommentAsync(Id, commentDto.Id);
            _comments?.Remove(commentDto);
            _commentCount--;
            Snackbar.Add("Comment deleted successfully", Severity.Success);
        }
    }

    private void NavigateBack()
    {
        Navigation.NavigateTo("issues");
    }

    private static Color GetPriorityColor(Priority priority)
    {
        return priority switch
        {
            Priority.High => Color.Error,
            Priority.Medium => Color.Warning,
            _ => Color.Default
        };
    }

    private static Color GetStatusColor(Status status)
    {
        return status switch
        {
            Status.InProgress => Color.Primary,
            Status.Done => Color.Success,
            Status.DidNotComplete => Color.Error,
            _ => Color.Default
        };
    }

    private static TimeSpan GetTimeSpan(int seconds)
    {
        return TimeSpan.FromSeconds(seconds);
    }

    private static string FormatTime(int seconds)
    {
        var time = GetTimeSpan(seconds);
        var totalHours = (int)Math.Floor(time.TotalHours);

        return $"{totalHours} h {time.Minutes} m {time.Seconds} s";
    }

    public class InputModel
    {
        [Required]
        [StringLength(1000, ErrorMessage = "Description length can't be more than 1000 characters.")]
        public string Comment { get; set; }
    }

}