@page "/"
@using DotTracked.Shared.Constants
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]

<PageTitle>Home</PageTitle>

<MudContainer>
    <AuthorizeView>
        @if (context.User.IsInRole(Roles.Admin))
        {
            <MudText>Signed in as an Admin</MudText>
        }
        else
        {
            <MudText>Signed in as a User</MudText>
        }
    </AuthorizeView>
</MudContainer>

@code { }